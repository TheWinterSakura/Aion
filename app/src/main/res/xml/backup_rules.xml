<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup rules for ClassSchedule app
   Excludes sensitive data like API keys from backup
-->
<full-backup-content>
    <!-- 排除 DataStore 中的敏感数据 -->
    <exclude domain="sharedpref" path="datastore/settings.preferences_pb"/>
    
    <!-- 可以包含课程数据库 -->
    <include domain="database" path="course_database"/>
    <include domain="database" path="schedule_database"/>
</full-backup-content>
